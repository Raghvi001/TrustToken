      "parameters": {
        "jsCode": "function generateHash(str) {\n    let hash = 0;\n    if (!str) return Math.random().toString(36).substring(7);\n    for (let i = 0; i < str.length; i++) {\n        const char = str.charCodeAt(i);\n        hash = ((hash << 5) - hash) + char;\n        hash = hash & hash;\n    }\n    return Math.abs(hash).toString(16);\n}\n\nreturn items.map(item => {\n    const url = (item.json.link || item.json.guid || \"\").toString();\n    let rawHtml = item.json.content || item.json.contentSnippet || \"\";\n    \n    if (typeof rawHtml !== 'string') { rawHtml = JSON.stringify(rawHtml); }\n\n    const cleanText = rawHtml\n        .replace(/<[^>]*>?/gm, ' ')\n        .replace(/\\s+/g, ' ')\n        .trim();\n\n    const uniqueId = generateHash(url);\n\n    return {\n        json: {\n            // THE NEWS STORY MUST BE THE FIRST FIELD\n            pageContent: cleanText, \n            row_id: uniqueId, \n            metadata: {\n                source_url: url,\n                title: item.json.title || \"No Title\",\n                publish_date: item.json.pubDate || new Date().toISOString()\n            }\n        }\n    };\n});"
