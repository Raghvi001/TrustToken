    {
      "parameters": {
        "jsCode": "// Helper function to generate a consistent unique ID\nfunction generateId(str) {\n    if (!str) return Math.random().toString(36).substring(2, 15);\n    let hash = 0;\n    for (let i = 0; i < str.length; i++) {\n        const char = str.charCodeAt(i);\n        hash = ((hash << 5) - hash) + char;\n        hash = hash & hash; \n    }\n    return Math.abs(hash).toString(16);\n}\n\n// Helper to decode HTML entities (e.g., &amp; -> &)\nfunction decodeHtml(html) {\n    const txt = document.createElement(\"textarea\");\n    txt.innerHTML = html;\n    return txt.value;\n}\n\nreturn items.map(item => {\n    // 1. Get URL safely\n    const url = (item.json.link || item.json.guid || \"\").toString().trim();\n    \n    // 2. Get Raw Content\n    let rawContent = item.json.content || item.json.contentSnippet || item.json.description || \"\";\n    \n    if (Array.isArray(rawContent)) { \n        rawContent = rawContent.join(\" \"); \n    }\n    \n    // 3. Advanced Cleaning\n    // Remove scripts and styles first\n    let cleanText = rawContent\n        .replace(/<script\\b[^<]*(?:(?!<\\/script>)<[^<]*)*<\\/script>/gi, \" \")\n        .replace(/<style\\b[^<]*(?:(?!<\\/style>)<[^<]*)*<\\/style>/gi, \" \")\n        .replace(/<[^>]*>?/gm, \" \") // Remove remaining tags\n        .replace(/&nbsp;/g, \" \")    // Decode common entities manually\n        .replace(/&amp;/g, \"&\")\n        .replace(/&lt;/g, \"<\")\n        .replace(/&gt;/g, \">\")\n        .replace(/\\s+/g, \" \")       // Normalize whitespace\n        .trim();\n\n    // Fallback if content is empty after cleaning\n    if (!cleanText || cleanText.length < 10) {\n        cleanText = `Headline: ${item.json.title || \"Untitled Article\"}`;\n    }\n\n    // 4. Generate ID based on URL to prevent duplicates\n    const uniqueId = \"doc_\" + generateId(url);\n\n    return {\n        json: {\n            // This is what gets embedded\n            pageContent: cleanText, \n            \n            // This is stored alongside the vector for filtering\n            metadata: {\n                source_url: url,\n                title: item.json.title || \"Untitled\",\n                publish_date: item.json.pubDate ? new Date(item.json.pubDate).toISOString() : new Date().toISOString(),\n                article_id: uniqueId,\n                content_source: item.json.source || \"RSS Feed\"\n            }\n        }\n    };\n});"
      },
